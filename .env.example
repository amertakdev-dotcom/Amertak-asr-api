# Render will inject PORT automatically
PORT=3000

# Choose backend: hf-api (cloud) or transformers (local)
# NOTE: Render free/starter tier has ~512MB RAM.
# Local models need Standard tier or higher. Use hf-api for Starter.
DEFAULT_BACKEND=hf-api

# Hugging Face Inference API (cloud backend)
HF_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxx
HF_API_MODEL=ksoky/whisper-large-khmer-asr

# Local Transformers.js model (only if you have enough RAM on Render)
TRANSFORMERS_MODEL=seanghay/whisper-small-khmer
